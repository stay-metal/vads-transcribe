# BloodTranscripts — серверные секреты/настройки (скопируйте в deploy/.env).
# НЕ коммитьте реальный .env. Ключи генерируйте независимо.

# --- единственный пользователь (общие креды) ---
BLOODTRANSCRIPTS_USER=admin
# bcrypt-хэш пароля. Сгенерировать:
#   python -c "from gigaam_transcriber.server.security import hash_password; print(hash_password('ВАША-ДЛИННАЯ-ФРАЗА'))"
BLOODTRANSCRIPTS_PASSWORD_HASH=

# --- РАЗДЕЛЬНЫЕ ключи (должны различаться!) ---
# Подпись cookie сессии:    python -c "import secrets; print(secrets.token_urlsafe(48))"
BLOODTRANSCRIPTS_SESSION_KEY=
# Шифрование секретов at-rest (Я.Диск-токен, M5): python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BLOODTRANSCRIPTS_FERNET_KEY=

# --- диаризация ---
HF_TOKEN=

# --- Яндекс.Диск OAuth (опц.; приложение oauth.yandex.ru, право cloud_api:disk.read) ---
# Без них работает ручной debug-token; с ними — кнопка «Подключить» + авто-refresh.
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
# Redirect URI должен совпадать с зарегистрированным в приложении Яндекса.
BLOODTRANSCRIPTS_OAUTH_REDIRECT=https://ВАШ-ДОМЕН/api/yandex/oauth/callback
# Папка-allowlist на Диске (ingest ограничен ею):
# BLOODTRANSCRIPTS_YANDEX_WATCH_DIR=/Записи

# --- локальный watch (страница «Источники») ---
# Корень, ниже которого разрешено выбирать наблюдаемую папку (allowlist):
# BLOODTRANSCRIPTS_LOCAL_WATCH_ROOT=/watch

# --- пути/устройство ---
BLOODTRANSCRIPTS_DATA_DIR=/data
BLOODTRANSCRIPTS_DEVICE=cuda

# --- L2 «второе мнение» (faster-whisper), опц. ---
# GIGAAM_WHISPER_MODEL=small
# GIGAAM_WHISPER_COMPUTE=int8

# --- транспорт (за nginx по TLS) ---
BLOODTRANSCRIPTS_COOKIE_SECURE=1
BLOODTRANSCRIPTS_REQUIRE_HTTPS=1

# --- лимиты (предохранители от abuse; не типичный размер) ---
# BLOODTRANSCRIPTS_MAX_FILE_SIZE=3221225472
# BLOODTRANSCRIPTS_MAX_RECORDING_TOTAL=5368709120
# BLOODTRANSCRIPTS_MAX_DURATION_SEC=14400

# --- анти-brute-force логина (дефолты разумные; глобальный порог держите с запасом над per-IP) ---
# BLOODTRANSCRIPTS_LOGIN_MAX_FAILURES=10
# BLOODTRANSCRIPTS_LOGIN_LOCKOUT_SECONDS=60
# BLOODTRANSCRIPTS_LOGIN_GLOBAL_MAX_FAILURES=50
# BLOODTRANSCRIPTS_LOGIN_MAX_LOCKOUT_SECONDS=3600
# BLOODTRANSCRIPTS_SESSION_MAX_AGE=43200
